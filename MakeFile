.PHONY: all init fmt tidy build-frontend build-mac-amd64 build-mac-arm64 build-linux-amd64 build-linux-arm64 build-windows-amd64 build-windows-arm64

# ------------------------------
# 最终构建：只编译 1 次前端！
# ------------------------------
all: build-all

# 先编译前端 → 再编译所有平台
build-all: fmt tidy build-frontend \
	build-mac-amd64 \
	build-mac-arm64 \
	build-linux-amd64 \
	build-linux-arm64 \
	build-windows-amd64 \
	build-windows-arm64

# --- Go Commands ---
init:
	go mod init

fmt:
	go fmt ./...

tidy:
	go mod tidy

# --- Frontend 只编译 1 次 ---
build-frontend: frontend/node_modules
	@echo ">>> Building frontend..."
	mkdir -p releases
	cd frontend && npm run build
	rm -rf releases/web
	mv frontend/dist releases/web

frontend/node_modules: frontend/package.json
	@echo ">>> Installing frontend dependencies..."
	cd frontend && npm install

# ------------------------------
# 所有 GO 编译：不再依赖 build-frontend！
# ------------------------------
build-mac-amd64:
	@echo ">>> Building macOS amd64..."
	mkdir -p releases/darwin-amd64
	CGO_ENABLED=0 GOOS=darwin GOARCH=amd64 go build -trimpath -ldflags "-w -s" -o releases/darwin-amd64/billo-hub ./cmd
	cp config.yaml releases/darwin-amd64/
	cp -r releases/web releases/darwin-amd64/

build-mac-arm64:
	@echo ">>> Building macOS arm64..."
	mkdir -p releases/darwin-arm64
	CGO_ENABLED=0 GOOS=darwin GOARCH=arm64 go build -trimpath -ldflags "-w -s" -o releases/darwin-arm64/billo-hub ./cmd
	cp config.yaml releases/darwin-arm64/
	cp -r releases/web releases/darwin-arm64/

build-linux-amd64:
	@echo ">>> Building linux amd64..."
	mkdir -p releases/linux-amd64
	CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags "-w -s" -o releases/linux-amd64/billo-hub ./cmd
	cp config.yaml releases/linux-amd64/
	cp -r releases/web releases/linux-amd64/

build-linux-arm64:
	@echo ">>> Building linux arm64..."
	mkdir -p releases/linux-arm64
	CGO_ENABLED=0 GOOS=linux GOARCH=arm64 go build -trimpath -ldflags "-w -s" -o releases/linux-arm64/billo-hub ./cmd
	cp config.yaml releases/linux-arm64/
	cp -r releases/web releases/linux-arm64/

build-windows-amd64:
	@echo ">>> Building windows amd64..."
	mkdir -p releases/windows-amd64
	CGO_ENABLED=0 GOOS=windows GOARCH=amd64 go build -trimpath -ldflags "-w -s" -o releases/windows-amd64/billo-hub.exe ./cmd
	cp config.yaml releases/windows-amd64/
	cp -r releases/web releases/windows-amd64/

build-windows-arm64:
	@echo ">>> Building windows arm64..."
	mkdir -p releases/windows-arm64
	CGO_ENABLED=0 GOOS=windows GOARCH=arm64 go build -trimpath -ldflags "-w -s" -o releases/windows-arm64/billo-hub.exe ./cmd
	cp config.yaml releases/windows-arm64/
	cp -r releases/web releases/windows-arm64/